# Copiá este archivo como .env.local y completá con los valores de tu instancia.
# Para desarrollo local con supabase CLI: corré `supabase status` para obtener
# las URLs y keys después de `supabase start`.
#
# Para Supabase Cloud: encontrás estos valores en
# https://supabase.com/dashboard/project/<tu-proyecto>/settings/api

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-de-supabase-status>
